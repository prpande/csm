{
  // Standalone lint-only project for type-aware ESLint. typescript-eslint needs
  // ONE project spanning every linted file; the build tsconfigs are narrow
  // (tsconfig.json → main/preload CommonJS; tsconfig.renderer.json → renderer
  // ESM+JSX) and conflict on module/jsx, so this is its own config with jsx + DOM
  // + node enabled. noEmit because linting only type-checks.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "node",
      "vite/client",
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  "include": ["src", "test", "e2e", "vite.config.ts", "playwright.config.ts"]
}
